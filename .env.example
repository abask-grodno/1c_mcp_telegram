BOT_TOKEN=
# AI model configuration
AI_MODEL_PROVIDER=deepseek  # deepseek, openai, anthropic, etc.
AI_MODEL_API_KEY=
AI_MODEL_BASE_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL_NAME=deepseek-chat
# URL HTTP JSON-RPC шлюза MCP для 1С (как настроено на вашей стороне)
MCP_SERVER_URL=http://127.0.0.1:8080/mcp
# Basic authentication for MCP server (optional)
MCP_AUTH_USERNAME=
MCP_AUTH_PASSWORD=
# Уровень логирования приложения (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# Путь к файлу логов (если пусто — только stdout)
LOG_FILE=logs/bot.log
# Ротация логов
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
# Максимальная длина payload в логах MCP
MCP_LOG_PAYLOAD_MAX_LEN=4000
# Максимальное количество итераций обработки запроса через MCP/DeepSeek
MAX_ITERATIONS=5
